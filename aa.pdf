func LoadOrSetupConfig(configPath string) (*Config, error) {
	fmt.Println("📋 Checking configuration... / 正在检查配置...")

	// 检查配置文件是否存在
	if _, err := os.Stat(configPath); os.IsNotExist(err) {
		fmt.Printf("❌ Configuration file not found: %s\n", configPath)
		fmt.Printf("❌ 未找到配置文件: %s\n", configPath)

		fmt.Println("\n📝 Generating template configuration file...")
		fmt.Println("📝 正在生成模板配置文件...")
		templateConfig := generateTemplateConfig()
		if err := SaveConfig(configPath, templateConfig); err != nil {
			return nil, fmt.Errorf("failed to generate template config: %w", err)
		}
		fmt.Printf("✅ Template configuration saved to: %s\n", configPath)
		fmt.Printf("✅ 模板配置已保存到: %s\n", configPath)

		fmt.Println("\n" + strings.Repeat("=", 60))
		fmt.Println("📋 NEXT STEPS / 下一步操作:")
		fmt.Println(strings.Repeat("=", 60))
		fmt.Println("1. Edit the configuration file / 编辑配置文件:")
		fmt.Printf("   → %s\n", configPath)
		fmt.Println("2. Configure your AI model (api_key, base_url, model_name)")
		fmt.Println("   配置你的 AI 模型 (API密钥、地址、模型名称)")
		fmt.Println("3. Configure channels if needed (feishu, qq, dingtalk, wework)")
		fmt.Println("   按需配置渠道 (飞书、QQ、钉钉、企业微信)")
		fmt.Println("4. Save the file and run the program again")
		fmt.Println("   保存文件后重新运行程序")
		fmt.Println(strings.Repeat("=", 60))

		fmt.Println("\n💡 Tip: You can also use the interactive setup wizard to configure.")
		fmt.Println("💡 提示: 你也可以使用交互式配置向导来完成配置。")

		if !askForSetup() {
			return nil, fmt.Errorf("configuration file not found and setup declined")
		}

		lang := selectLanguage()

		config, err := InteractiveConfig(lang)
		if err != nil {
			return nil, fmt.Errorf("setup failed: %w", err)
		}

		if err := SaveConfig(configPath, config); err != nil {
			return nil, fmt.Errorf("save config failed: %w", err)
		}

		fmt.Printf("✅ Configuration saved to: %s\n", configPath)
		fmt.Printf("✅ 配置已保存到: %s\n", configPath)
		return config, nil
	}

	// 配置文件存在，加载
	config, err := LoadConfig(configPath)
	if err != nil {
		fmt.Printf("⚠️  Failed to load config: %v\n", err)
		fmt.Printf("⚠️  加载配置失败: %v\n", err)

		if !askForSetup() {
			return nil, fmt.Errorf("load config failed: %w", err)
		}

		lang := selectLanguage()
		config, err := InteractiveConfig(lang)
		if err != nil {
			return nil, fmt.Errorf("setup failed: %w", err)
		}

		if err := SaveConfig(configPath, config); err != nil {
			return nil, fmt.Errorf("save config failed: %w", err)
		}

		fmt.Printf("✅ Configuration saved to: %s\n", configPath)
		return config, nil
	}

	// 验证配置 - 修复：正确接收两个返回值
	valid, reason := ValidateConfig(config)
	if !valid {
		fmt.Printf("❌ Configuration invalid: %s\n", reason)
		fmt.Printf("❌ 配置无效: %s\n", reason)
		printMissingInfo(config)

		if !askForSetup() {
			return nil, fmt.Errorf("invalid configuration: %s", reason)
		}

		lang := selectLanguage()
		config, err := InteractiveConfig(lang)
		if err != nil {
			return nil, fmt.Errorf("setup failed: %w", err)
		}

		if err := SaveConfig(configPath, config); err != nil {
			return nil, fmt.Errorf("save config failed: %w", err)
		}

		fmt.Printf("✅ Configuration saved to: %s\n", configPath)
		return config, nil
	}

	fmt.Println("✅ Configuration is valid / 配置有效")
	return config, nil
}

// SaveConfig 保存配置到文件
func SaveConfig(configPath string, config *Config) error {
	// 确保目录存在
	configDir := filepath.Dir(configPath)
	if err := os.MkdirAll(configDir, 0755); err != nil {
		return fmt.Errorf("创建配置目录失败: %w", err)
	}

	// 序列化配置
	data, err := yaml.Marshal(config)
	if err != nil {
		return fmt.Errorf("序列化配置失败: %w", err)
	}

	// 写入文件
	if err := os.WriteFile(configPath, data, 0644); err != nil {
		return fmt.Errorf("写入配置文件失败: %w", err)
	}

	return nil
}

func typewriter(text string, delay time.Duration) {
	for _, ch := range text {
		fmt.Print(string(ch))
		time.Sleep(delay)
	}
	fmt.Println()
}

func showSplash() {
	// 使用 color 库美化
	cyan := color.New(color.FgCyan, color.Bold)
	yellow := color.New(color.FgYellow)
	green := color.New(color.FgGreen)

	cyan.Println("╔════════════════════════════════════════════════════════╗")
	cyan.Println("║    🐱🐾 Klaw - Local Agent System Powered by LLM  🤖   ║")
	cyan.Println("╚════════════════════════════════════════════════════════╝")

	typewriter("", 0) // 空行

	// 打字机效果
	typewriter("✨ Initializing AI Agent System...", 30*time.Millisecond)
	time.Sleep(1000 * time.Millisecond)

	typewriter("📚 Loading Skills...", 30*time.Millisecond)
	yellow.Println("   → Skills are modular capabilities that extend AI functionality")
	yellow.Println("   → Skills can be: web_search, code_executor, file_processor, etc.")
	time.Sleep(1000 * time.Millisecond)

	typewriter("🔧 Loading Tools...", 30*time.Millisecond)
	yellow.Println("   → Tools are external utilities that Skills can invoke")
	yellow.Println("   → Tools provide: API access, system commands, data processing")
	time.Sleep(800 * time.Millisecond)

	typewriter("🤖 Initializing Agents...", 30*time.Millisecond)
	time.Sleep(500 * time.Millisecond)

	green.Println("\n✅ System Ready!")

	yellow.Println("\n💡 Need help or Commercial inquiries? Contact:")
	green.Println(" 📱 WeChat: diligently1016 | 📧 Email: diligently1016@163.com")

	fmt.Println()
}

