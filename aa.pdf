}

// Agent 接口定义
type Agent interface {
	Name() string
	Generate(ctx context.Context, input string) (string, error)
	GetType() AgentType
}

// ====================== LLM Agent 实现 ======================

// LLMAgent LLM Agent实现
type LLMAgent struct {
	name          string
	modelConfig   *ModelConfig
	systemMessage string
	temperature   float64
	maxTokens     int
	enabledTools  []string
	httpClient    *http.Client
	callback      AgentCallback // 改为回调接口，可选

	// 新增字段
	memory             *MemoryStore  // 记忆存储
	skillsLoader       *SkillsLoader // 技能加载器
	toolRegistry       *ToolRegistry // 工具注册表
	maxIterations      int           // 最大迭代次数
	workspace          string        // 工作空间
	hasMemory          bool          // 是否启用记忆
	memoryWindow       int           // 记忆窗口
	fileLogger         *log.Logger
	hotMessages        []map[string]interface{}
	tokenCounter       *tiktoken.Tiktoken // token 计数器
	coldMessagesPath   string
	taskShell          *PersistentShell
	usePersistentShell bool
}

func NewLLMAgent(config AgentConfig, modelConfig *ModelConfig, callback AgentCallback, globalConfig *Config, filelogger *log.Logger) *LLMAgent {
	// 创建工作空间
	workspace := globalConfig.Workspace
	if workspace == "" {
		workspace = "./"
	}

	// 确定是否启用记忆
	hasMemory := globalConfig.MemoryConfig.Enabled
	if config.HasMemory != nil {
		hasMemory = *config.HasMemory
	}

	memoryWindow := globalConfig.MemoryConfig.MemoryWindow
	if config.MemoryWindow != nil {
		memoryWindow = *config.MemoryWindow
	}
	if memoryWindow <= 0 {
		memoryWindow = 50
	}

	memoryBaseDir := globalConfig.MemoryConfig.BaseDir
	if memoryBaseDir == "" {
		memoryBaseDir = filepath.Join(workspace, "memories")
	}

	agentMemoryDir := filepath.Join(memoryBaseDir, config.Name)
	os.MkdirAll(agentMemoryDir, 0755)

	// 创建记忆存储（不再需要recorder）
	var memory *MemoryStore
	if hasMemory {
		memory = NewMemoryStore(agentMemoryDir, db, config.Name, memoryWindow)
	}

	// 创建技能加载器（不再需要recorder）
	log.Println("begin set skill, DisEnabled:", globalConfig.SkillsConfig.DisEnabled)
	var skillsLoader *SkillsLoader
	if globalConfig.SkillsConfig.DisEnabled != true {
		skillsLoader = NewSkillsLoader(workspace, config.Name, globalConfig.SkillsConfig.GlobalDir)
		if err := skillsLoader.LoadAllSkills(); err != nil {
			// 通过callback记录错误
			log.Println("加载技能失败:", err)
			if callback != nil {
				callback.OnAgentError(config.Name, err, "加载技能失败")
			}
		}
	}

	// 创建工具注册表（工具不再需要recorder）
	toolRegistry := NewToolRegistry()
	disabledTools := make(map[string]bool)
	if globalConfig.ToolsConfig.DisabledTools != nil {
		for _, tool := range globalConfig.ToolsConfig.DisabledTools {
			disabledTools[tool] = true
		}
	}

	if globalConfig.ToolsConfig.Enabled != false {
		toolRegistry.Register(NewReadFileTool(workspace))
		toolRegistry.Register(NewWriteFileTool(workspace))
		toolRegistry.Register(NewListDirTool(workspace))

		toolRegistry.Register(NewSearchHistoryTool(db))
		toolRegistry.Register(NewGetStatsTool(db))
		toolRegistry.Register(NewKnowledgeTool(db, config.Name))

		toolRegistry.Register(NewCreateTodoTool(db))
		toolRegistry.Register(NewListTodosTool(db))
		toolRegistry.Register(NewGetTodoTool(db))
		toolRegistry.Register(NewUpdateTodoTool(db))
		toolRegistry.Register(NewCancelTodoTool(db))

		if globalConfig.EmailConfig.Enabled && globalConfig.EmailConfig.SMTPHost != "" {
			emailTool := NewEmailTool(&globalConfig.EmailConfig, filelogger)
			toolRegistry.Register(emailTool)
			filelogger.Printf("[INFO] Email工具已注册 (SMTP: %s)", globalConfig.EmailConfig.SMTPHost)
		} else {
			filelogger.Printf("[INFO] Email工具未注册（未配置）")
		}

		documentTool := NewDocAnalyzeReplace(workspace, filelogger)
		toolRegistry.Register(documentTool)

		filelogger.Printf("[INFO] TODO工具已注册")

		// if !disabledTools["http"] {
		// 	toolRegistry.Register(NewHTTPTool())
		// 	filelogger.Printf("[INFO] HTTP工具已注册")
		// }
		// // 如果未禁用 WebExtract 工具，则创建并注册
		// if !disabledTools["webextract"] {
		// 	browserTool := NewBrowserTool(workspace, globalConfig.Headless)
		// 	extractTool := NewWebExtractTool(browserTool) // 传入 browserTool
		// 	toolRegistry.Register(extractTool)
		// 	filelogger.Printf("[INFO] WebExtract工具已注册")
		// }

		// // 同时也要注册 BrowserTool 本身（如果需要单独使用）
		// toolRegistry.Register(browserTool)
		// filelogger.Printf("[INFO] Browser工具已注册")

		// if !disabledTools["websocket"] {
		// 	toolRegistry.Register(NewWebSocketTool())
		// 	filelogger.Printf("[INFO] Browser工具已注册")
		// 	filelogger.Printf("[INFO] WebSocket工具已注册")
		// }

		// if !disabledTools["camera"] {
		// 	toolRegistry.Register(NewCameraTool(workspace))
		// 	filelogger.Printf("[INFO] 摄像头工具已注册")
		// }

		// if !disabledTools["audio"] {
		// 	toolRegistry.Register(NewAudioTool(workspace))
		// 	filelogger.Printf("[INFO] 音频工具已注册")
		// }

		toolRegistry.Register(NewCLITool(workspace))

		// toolRegistry.Register(NewNPMTool(workspace))
		// toolRegistry.Register(NewMouseTool())
		// toolRegistry.Register(NewKeyboardTool())

		// if globalConfig.GitTools != nil && globalConfig.GitTools.Enabled {
		// 	gitTool := NewGitTool(workspace)
		// 	toolRegistry.Register(gitTool)

		// 	// GitHub 集成（如果有token）
		// 	if globalConfig.GitTools.GitHubToken != "" {
		// 		githubTool := NewGitHubTool(workspace, globalConfig.GitTools.GitHubToken)
		// 		toolRegistry.Register(githubTool)
		// 	}

		// 	// 代码审查
		// 	if globalConfig.GitTools.EnableReview {
		// 		reviewTool := &CodeReviewTool{
		// 			gitTool: gitTool,
		// 			rules:   loadReviewRules(globalConfig.GitTools.ReviewRules),
		// 		}
		// 		toolRegistry.Register(reviewTool)
		// 	}

		// 	// 自动提交（如果启用）
		// 	if globalConfig.GitTools.AutoCommit {
		// 		autoCommitTool := &AutoCommitTool{
		// 			gitTool:  gitTool,
		// 			pattern:  globalConfig.GitTools.AutoCommitPattern,
		// 			message:  globalConfig.GitTools.AutoCommitMessage,
		// 			interval: time.Duration(globalConfig.GitTools.AutoCommitInterval) * time.Minute,
		// 		}
		// 		toolRegistry.Register(autoCommitTool)
		// 	}
		// }

		if skillsLoader != nil {
			toolRegistry.Register(NewListSkillsTool(skillsLoader))
			toolRegistry.Register(NewUseSkillTool(skillsLoader, toolRegistry))
		}

	}

	maxIterations := config.MaxIterations
	if maxIterations <= 0 {
		maxIterations = 120 // 设置默认值
	}

	tkm, _ := tiktoken.GetEncoding("cl100k_base")

	usePersistentShell := true
	if globalConfig != nil && globalConfig.Runtime.SemaphoreLimit > 0 {
		// 可以通过配置控制
		usePersistentShell = true
	}

	return &LLMAgent{
		name:               config.Name,
		modelConfig:        modelConfig,
		systemMessage:      config.SystemMessage,
		temperature:        config.Temperature,
		maxTokens:          config.MaxTokens,
		enabledTools:       config.EnabledTools,
		httpClient:         &http.Client{Timeout: 120 * time.Second},
		callback:           callback,
		memory:             memory,
		skillsLoader:       skillsLoader,
		toolRegistry:       toolRegistry,
		maxIterations:      maxIterations,
		workspace:          workspace,
		hasMemory:          hasMemory,
		memoryWindow:       memoryWindow,
		fileLogger:         filelogger,
		tokenCounter:       tkm,
		usePersistentShell: usePersistentShell,
	}
}

// Name 返回Agent名称
func (a *LLMAgent) Name() string {
	return a.name
}

// GetType 返回Agent类型
func (a *LLMAgent) GetType() AgentType {
	return AgentTypeCustom
}

func formatMessages(messages []map[string]interface{}) string {
	var builder strings.Builder
	// 遍历消息切片，完整打印每个消息的键值对（无截断）
	for i, msg := range messages {
		builder.WriteString(fmt.Sprintf("输入消息%d：%+v\n", i+1, msg))
	}
	// 去掉最后一个多余的换行，保持日志整洁
	return strings.TrimSuffix(builder.String(), "\n")
}

// calcMessagesLength calculates total characters in messages
func (a *LLMAgent) calcMessagesLength(messages []map[string]interface{}) int {
	total := 0
	total = a.calcMessagesTokens(messages)
	return total
}

func (a *LLMAgent) truncateLongMessages(messages []map[string]interface{}) []map[string]interface{} {
	result := make([]map[string]interface{}, len(messages))
	keepLastN := 5
	startIdx := len(messages) - keepLastN
	if startIdx < 0 {
		startIdx = 0
	}

	for i, msg := range messages {
		// 深拷贝消息，避免修改原数据
		clonedMsg := make(map[string]interface{})
		for k, v := range msg {
			clonedMsg[k] = v
		}

		role, _ := clonedMsg["role"].(string)
		content, ok := clonedMsg["content"].(string)
		if !ok {
			result[i] = clonedMsg
			continue
		}

		// 判断是否在最后5条内
		isRecent := i >= startIdx

		switch role {
		case "assistant":
			// assistant 消息超过200字符截断（所有消息都处理）
			if len(content) > 200 {
				originalLen := len(content)
				clonedMsg["content"] = truncate(content, 200)
				clonedMsg["truncated"] = true
				clonedMsg["original_length"] = originalLen
				a.fileLogger.Printf("[Compress] assistant消息截断: %d→200字符", originalLen)
			}

		case "tool":
			// 检查是否是读取 skill.md 的操作
			toolName, _ := clonedMsg["name"].(string)
			isReadSkill := toolName == "read_file" && strings.Contains(content, ".skill.md")

			// 判断截断阈值
			threshold := 300
			if isRecent {
				threshold = 1500 // 最近5条内的tool，阈值提高到1500
			}

			// 非读取 skill.md 的 tool 消息超过阈值截断
			if !isReadSkill && len(content) > threshold {
				originalLen := len(content)
				toolCallID, _ := clonedMsg["tool_call_id"].(string)

				clonedMsg["content"] = truncate(content, threshold)
				clonedMsg["truncated"] = true
				clonedMsg["original_length"] = originalLen
				clonedMsg["tool_call_id"] = toolCallID

				a.fileLogger.Printf("[Compress] tool msg truncated: %s (%d→%d字符, 是否最近5条:%v)", toolName, originalLen, threshold, isRecent)
			}
		}

		result[i] = clonedMsg
	}
	return result
}

type DiscardTool struct {
	name        string
	description string
	parameters  map[string]interface{}
	agent       *LLMAgent // 需要引用 LLMAgent 来操作消息
}

func (t *DiscardTool) Name() string {
	return t.name
}

func (t *DiscardTool) Description() string {
	return t.description
}

func (t *DiscardTool) Parameters() map[string]interface{} {
	return t.parameters
}

func (t *DiscardTool) Execute(ctx context.Context, params map[string]interface{}) (string, error) {
	toolCallIDs, ok := params["tool_call_ids"].([]interface{})
	if !ok {
		return "", fmt.Errorf("tool_call_ids 参数格式错误")
	}

	reason, _ := params["reason"].(string)

	// 收集要丢弃的ID
	discardSet := make(map[string]bool)
	for _, id := range toolCallIDs {
		if idStr, ok := id.(string); ok {
			discardSet[idStr] = true
		}
	}
	// 过滤消息 - 需要访问 agent 的 hotMessages
	// 这里需要在 LLMAgent 中暴露一个方法来处理
	return t.agent.discardMessages(discardSet, reason)
}

func (a *LLMAgent) registerDiscardTool() {
	if a.toolRegistry == nil {
		return
	}

	discardTool := &DiscardTool{
		name: "discard",
		description: `丢弃指定的工具调用结果，从上下文中移除。
当你认为某些工具结果不再需要时（如过时的调试信息、已处理的中间结果、冗余的输出等），
可以使用此工具主动清理，释放上下文空间。

使用场景：
- 工具返回了大量信息，但只需要其中的关键结论
- 调试信息已经使用完毕
- 某些中间步骤的结果不再需要
- 想要精简上下文，让后续对话更聚焦

注意：
- 只能丢弃 tool 类型的消息
- 丢弃后无法恢复，如需再次查看需要重新执行工具
- 建议保留重要的决策依据和最终结果`,
		parameters: map[string]interface{}{
			"type": "object",
			"properties": map[string]interface{}{
				"tool_call_ids": map[string]interface{}{
					"type":        "array",
					"description": "要丢弃的工具调用ID列表",
					"items": map[string]interface{}{
						"type": "string",
					},
				},
				"reason": map[string]interface{}{
					"type":        "string",
					"description": "丢弃原因（用于日志）",
				},
			},
			"required": []string{"tool_call_ids"},
		},
		agent: a,
	}

	a.toolRegistry.Register(discardTool)
}

// 在 LLMAgent 中添加丢弃消息的方法
func (a *LLMAgent) discardMessages(discardSet map[string]bool, reason string) (string, error) {
	discarded := []string{}
	newMessages := []map[string]interface{}{}

	for _, msg := range a.hotMessages {
		role, _ := msg["role"].(string)
		if role == "tool" {
			if toolCallID, ok := msg["tool_call_id"].(string); ok {
				if discardSet[toolCallID] {
					discarded = append(discarded, toolCallID)
					a.fileLogger.Printf("[Memory] AI主动丢弃工具结果: %s, 原因: %s", toolCallID, reason)
					continue
				}
			}
		}
		newMessages = append(newMessages, msg)
	}

	if len(discarded) == 0 {
		return "未找到要丢弃的工具结果，请检查 tool_call_id 是否正确", nil
	}

	a.hotMessages = newMessages

	return fmt.Sprintf("已丢弃 %d 个工具结果: %s", len(discarded), strings.Join(discarded, ", ")), nil
}

func (a *LLMAgent) buildHistorySummary(coldMessages []map[string]interface{}, lastCount int, existingSummary string) (string, int) {
	if len(coldMessages) == 0 {
		return existingSummary, 0
	}

	var builder strings.Builder

	// 确定起始索引
	startIdx := lastCount
	if startIdx < 0 {
		startIdx = 0
	}

	// 如果没有新消息，直接返回已有摘要
	if startIdx >= len(coldMessages) {
		return existingSummary, len(coldMessages)
	}

	// 如果有已有的摘要，先写入
	if existingSummary != "" {
		builder.WriteString(existingSummary)

	}

	// 添加新增部分标题
	if startIdx == 0 {
		builder.WriteString("## Conversation Summary\n\n")
	}

	// 逐条输出新增的消息
	for i := startIdx; i < len(coldMessages); i++ {
		msg := coldMessages[i]
		role, _ := msg["role"].(string)
		content, _ := msg["content"].(string)

		// Role identifier
		roleMark := ""
		switch role {
		case "user":
			roleMark = "[User]"
		case "assistant":
			roleMark = "[Assistant]"
		case "tool":
			roleMark = "[Tool]"
		case "system":
			roleMark = "[System]"
		default:
			roleMark = fmt.Sprintf("[%s]", role)
		}

		// Handle different message types
		if role == "tool" {
			toolName, _ := msg["name"].(string)
			status, ok := msg["status"].(bool)
			statusText := "[OK]"
			if ok && !status {
				statusText = "[FAIL]"
			}
			builder.WriteString(fmt.Sprintf("%d. %s %s %s: %s\n",
				i+1, roleMark, toolName, statusText, truncate(content, 100)))

		} else if role == "assistant" {
			if toolCalls, ok := msg["tool_calls"].([]interface{}); ok && len(toolCalls) > 0 {
				toolNames := extractToolNames(toolCalls)
				if content != "" {
					builder.WriteString(fmt.Sprintf("%d. %s [calling:%s]: %s\n",
						i+1, roleMark, strings.Join(toolNames, ", "), truncate(content, 80)))
				} else {
					builder.WriteString(fmt.Sprintf("%d. %s [calling:%s]\n",
						i+1, roleMark, strings.Join(toolNames, ", ")))
				}
			} else if content != "" {
				builder.WriteString(fmt.Sprintf("%d. %s: %s\n", i+1, roleMark, truncate(content, 100)))
			} else {
				builder.WriteString(fmt.Sprintf("%d. %s: (empty)\n", i+1, roleMark))
			}
		} else {
			if content != "" {
				builder.WriteString(fmt.Sprintf("%d. %s: %s\n", i+1, roleMark, truncate(content, 100)))
			} else {
				builder.WriteString(fmt.Sprintf("%d. %s: (empty)\n", i+1, roleMark))
			}
		}
	}
	return builder.String(), len(coldMessages)
}

// extractToolNames extracts tool names from tool_calls
func extractToolNames(toolCalls []interface{}) []string {
	names := make([]string, 0)
	for _, tc := range toolCalls {
		if tcMap, ok := tc.(map[string]interface{}); ok {
			if funcMap, ok := tcMap["function"].(map[string]interface{}); ok {
				if name, ok := funcMap["name"].(string); ok {
					names = append(names, name)
				}
			}
		}
	}
	return names
}

// countMessagesByRole counts messages by role
func countMessagesByRole(messages []map[string]interface{}) (user, assistant, tool int) {
	for _, msg := range messages {
		role, _ := msg["role"].(string)
		switch role {
		case "user":
			user++
		case "assistant":
			assistant++
		case "tool":
			tool++
		}
	}
	return
}

// 从消息中提取关键事实（规则截断）
func (a *LLMAgent) extractFactsFromMessages(messages []map[string]interface{}) []string {
	var facts []string
	for _, msg := range messages {
		role, _ := msg["role"].(string)
		content, _ := msg["content"].(string)

		switch role {
		case "user":
			facts = append(facts, fmt.Sprintf("用户提问: %s", truncate(content, 100)))
		case "assistant":
			facts = append(facts, fmt.Sprintf("助手回复: %s", truncate(content, 100)))
		case "tool":
			toolName, _ := msg["name"].(string)
			status, _ := msg["status"].(bool)
			facts = append(facts, fmt.Sprintf("工具[%s]执行%s: %s",
				toolName, map[bool]string{true: "成功", false: "失败"}[status], truncate(content, 100)))
		}
	}
	return facts
}

func (a *LLMAgent) logMessagesDelta(messages []map[string]interface{}, round, lastLoggedMsgCount int) {
	if len(messages) <= lastLoggedMsgCount {
		return
	}
	newMsgs := messages[lastLoggedMsgCount:]
	a.fileLogger.Printf("[INFO]  Round %d: +%d new messages ===== ", round, len(newMsgs))
	for i, msg := range newMsgs {
		a.fileLogger.Printf("[新增消息%d] %+v", lastLoggedMsgCount+i+1, msg)
	}

}

func (a *LLMAgent) initTokenCounter() error {
	// 使用 OpenAI 的 cl100k_base 编码（GPT-4, GPT-3.5-turbo 使用）
	tkm, err := tiktoken.GetEncoding("cl100k_base")
	if err != nil {
		return fmt.Errorf("初始化 token 计数器失败: %w", err)
	}
	a.tokenCounter = tkm
	return nil
}

// countTokens 计算文本的 token 数量
func (a *LLMAgent) countTokens(text string) int {
	if a.tokenCounter == nil {
		// fallback: 估算，英文约4字符/token，中文约1.5字符/token
		runeCount := len([]rune(text))
		return runeCount / 2
	}
	tokens := a.tokenCounter.Encode(text, nil, nil)
	return len(tokens)
}

// calcMessagesTokens 计算消息列表的总 token 数
func (a *LLMAgent) calcMessagesTokens(messages []map[string]interface{}) int {
	total := 0
	for _, msg := range messages {
		// 计算 content 的 token
		if content, ok := msg["content"].(string); ok {
			total += a.countTokens(content)
		}
		// 计算 tool_calls 的 token
		if toolCalls, ok := msg["tool_calls"].([]interface{}); ok {
			if data, err := json.Marshal(toolCalls); err == nil {
				total += a.countTokens(string(data))
			}
		}
		// 计算 role 和 name 等字段的 token
		if role, ok := msg["role"].(string); ok {
			total += a.countTokens(role)
		}
		if name, ok := msg["name"].(string); ok {
			total += a.countTokens(name)
		}
		if toolCallID, ok := msg["tool_call_id"].(string); ok {
			total += a.countTokens(toolCallID)
		}
	}
	return total
}

func (a *LLMAgent) saveColdMessages(taskID string, coldMessages []map[string]interface{}) error {
	if a.coldMessagesPath == "" {
		a.coldMessagesPath = "logs/cold_messages"
	}

	// 确保目录存在
	if err := os.MkdirAll(a.coldMessagesPath, 0755); err != nil {
		return fmt.Errorf("创建目录失败: %w", err)
	}

	filePath := filepath.Join(a.coldMessagesPath, fmt.Sprintf("%s.json", taskID))

	data, err := json.MarshalIndent(coldMessages, "", "  ")
	if err != nil {
		return fmt.Errorf("序列化失败: %w", err)
	}

	if err := os.WriteFile(filePath, data, 0644); err != nil {
		return fmt.Errorf("写入文件失败: %w", err)
	}

	a.fileLogger.Printf("[INFO] coldMessages 已保存: %s (共%d条消息)", filePath, len(coldMessages))
	return nil
}

func (a *LLMAgent) Generate(ctx context.Context, input string) (string, error) {
	log.Printf("begin LLMAgent Generate")
	startTime := time.Now()

	memoryEvent := &MemoryEvent{
		AgentName:    a.name,
		AgentType:    "agent",
		UserQuestion: input,
		StartTime:    startTime,
		Status:       "pending",
	}
	lastLoggedMsgCount := 0
	a.registerDiscardTool()
	taskID := ""
	if id, ok := ctx.Value("task_id").(string); ok && id != "" {
		taskID = id
	} else {
		taskID = fmt.Sprintf("%s_%s", a.name, time.Now().Format("20060102150405"))
	}
	log.Printf("taskid[%s]", taskID)
	// 提取用户信息（如果有的话）
	if userID, ok := ctx.Value("user_id").(string); ok {
		memoryEvent.UserID = userID
	}

	if SessionID, ok := ctx.Value("session_id").(string); ok {
		memoryEvent.SessionID = SessionID
	}

	if userName, ok := ctx.Value("user_name").(string); ok {
		memoryEvent.UserName = userName
	}
	if channel, ok := ctx.Value("channel").(string); ok {
		memoryEvent.UserChannel = channel
	}

	if a.memory != nil {
		a.memory.SaveTaskLog(taskID, "START", fmt.Sprintf("Input:\n%s", input))
	}

	if a.usePersistentShell {
		terminalMgr := GetTerminalManager()
		workDir := a.workspace
		if workDir == "" {
			workDir = "."
		}
		shell, err := terminalMgr.GetOrCreateTerminal(taskID, workDir)
		if err != nil {
			a.fileLogger.Printf("[WARN] 创建任务终端失败: %v", err)
		} else {
			a.taskShell = shell
			a.fileLogger.Printf("[INFO] 任务 %s 创建终端: %s", taskID, shell.GetTerminalInfo())
		}
	}
	log.Printf("has GetOrCreateTerminal succ ")
	// 构建系统提示
	systemPrompt := a.buildSystemPrompt(taskID, input)
	if a.callback != nil {
		a.callback.OnAgentThinking(a.name, fmt.Sprintf("begin task[%s],finish: build systemprompt:%d", taskID, countTokens(systemPrompt)), "rec")
	}
	coldMessages := []map[string]interface{}{
		{
			"role":    "system",
			"content": systemPrompt,
		},
		{
			"role":    "user",
			"content": input,
		},
	}

	messages := []map[string]interface{}{
		{
			"role":    "system",
			"content": systemPrompt,
		},
		{
			"role":    "user",
			"content": input,
		},
	}

	historyMsgSummary := ""

	iteration := 0
	var finalOutput string
	var toolCalls []string
	var allToolResults []string
	var callChain []map[string]interface{}
	var totalDurationMs int64
	var toolCallSummary []string

	event_status := "failed"
	log.Printf("max iteration[%d]", a.maxIterations)

	const (
		compressMsgThreshold = 50 // Compress when >15 messages
		maxContextChars      = 12000
	)
	for iteration < a.maxIterations {
		iteration++

		a.hotMessages = messages
		currentChars := a.calcMessagesLength(messages)
		shouldCompress := len(messages) > compressMsgThreshold || currentChars > maxContextChars
		if shouldCompress {

			historyMsgSummary, _ = a.buildHistorySummary(coldMessages, lastLoggedMsgCount, historyMsgSummary)
			messages[1]["content"] = systemPrompt + historyMsgSummary //+ fmt.Printf("\n\n if you need look the old msg again, you can use tool relook ,config the right taskid and index of the conservation message to relook")

			originalLen := a.calcMessagesLength(messages)
			originalCount := len(messages)
			messages = a.truncateLongMessages(messages)
			newLen := a.calcMessagesLength(messages)
			newCount := len(messages)

			a.fileLogger.Printf("[INFO] Memory compressed: chars %d→%d (%.1f%%), msgs %d→%d", originalLen, newLen, float64(newLen)/float64(originalLen)*100, originalCount, newCount)

			if a.callback != nil {
				a.callback.OnAgentThinking(a.name, fmt.Sprintf("Context compressed: %d→%d messages,chars %d→%d (%.1f%%)",
					originalCount, newCount, originalLen, newLen, float64(newLen)/float64(originalLen)*100), "system")
			}
		}

		var iter_toolCallSummary []string

		// 记录请求消息（用于调试）
		inputMsgStr := formatMessages2(messages, lastLoggedMsgCount)
		lastLoggedMsgCount = len(messages)
		a.fileLogger.Printf("++++++++before callllm record")
		a.fileLogger.Printf("[INFO] call_llm | time: %s | iter: %d | msg len: %d | input: %s", time.Now().Format("2006-01-02 15:04:05"), iteration, len(messages), inputMsgStr)
		a.fileLogger.Printf("--------before callllm record")
		// 调用LLM
		if a.callback != nil {
			a.callback.OnAgentThinking(a.name, fmt.Sprintf("Begin logical analysis,thinking round[%d]", iteration), "rec")
		}
		response, err := a.callLLM(ctx, messages)
		if err != nil {
			a.fileLogger.Printf("[ERROR] LLM call fail: %v ；response:%v ；(发送消息数: %d)", err, response, len(messages))
			if a.callback != nil {
				a.callback.OnAgentThinking(a.name, fmt.Sprintf(" LLM call fail:%v", err), "rec")
			}
			return "", fmt.Errorf("LLM调用失败: %w", err)
		}
		cleanResponse := Clean(response.Content)

		a.fileLogger.Printf("++++++++")
		a.fileLogger.Printf("[INFO] LLM call succ content: %s", cleanResponse)
		a.fileLogger.Printf("[INFO] num of toolcalls: %d，detail: %v", len(response.ToolCalls), response.ToolCalls)
		a.fileLogger.Printf("--------")

		fullreponse := cleanResponse
		if len(response.ToolCalls) > 0 {

			toolInfo := "\n\n[工具调用]\n"
			for i, tc := range response.ToolCalls {
				toolInfo += fmt.Sprintf("%d. 工具: %s\n", i+1, tc.Name)
				// 提取工具参数的关键字段
				argsJSON, _ := json.Marshal(tc.Arguments)
				toolInfo += fmt.Sprintf("   参数: %s\n", string(argsJSON))
			}
			fullreponse = fullreponse + " toolInfo:" + toolInfo

		}

		if a.callback != nil {
			a.callback.OnLLMCall(a.name, inputMsgStr, truncate(fullreponse, 500), fmt.Sprintf("迭代%d，taskid:%s", iteration, taskID), a.countTokens(fullreponse))
		}

		assistantMsg := map[string]interface{}{
			"role":    "assistant",
			"content": cleanResponse,
		}

		if len(response.ToolCalls) > 0 {
			toolCallsData := make([]map[string]interface{}, len(response.ToolCalls))
			for i, tc := range response.ToolCalls {
				argsJSON, _ := json.Marshal(tc.Arguments)
				toolCalls = append(toolCalls, tc.Name)

				iter_toolCallSummary = append(iter_toolCallSummary, formatToolCall(tc.Name, tc.Arguments, false))
				toolCallsData[i] = map[string]interface{}{
					"id":   tc.ID,
					"type": "function",
					"function": map[string]interface{}{
						"name":      tc.Name,
						"arguments": string(argsJSON),
					},
				}
				if a.memory != nil {
					a.memory.SaveTaskLog(taskID, "TOOL_CALL", fmt.Sprintf("Tool: %s\nArgs: %s", tc.Name, truncate(string(argsJSON), 1000)))
				}
			}
			assistantMsg["tool_calls"] = toolCallsData

		}
		a.fileLogger.Printf("[INFO] 添加assistant消息，包含 %d 个工具调用", len(response.ToolCalls))
		a.fileLogger.Printf("toolcalls details:%v", response.ToolCalls)

		if a.callback != nil {
			a.callback.OnAgentThinking(a.name, fmt.Sprintf("[summary]will use tools: %s", iter_toolCallSummary), "rec")
		}

		messages = append(messages, assistantMsg)
		coldMessages = append(coldMessages, assistantMsg)

		if len(response.ToolCalls) > 0 && a.toolRegistry != nil {
			for _, toolCall := range response.ToolCalls {
				toolStartTime := time.Now()
				toolStep := map[string]interface{}{
					"type": "tool",
					"name": toolCall.Name,
				}

				// 记录工具调用
				if a.callback != nil {
					argsJSON, _ := json.Marshal(toolCall.Arguments)
					a.callback.OnAgentThinking(a.name, fmt.Sprintf("will use %s: %s", toolCall.Name, string(argsJSON)), "use_tool")
				}

				if toolCall.Name != "use_skill" {
					a.fileLogger.Printf("[INFO] 执行工具: %s, ID: %s", toolCall.Name, toolCall.ID)
				} else {
					skillName, _ := toolCall.Arguments["skill_name"].(string)
					a.fileLogger.Printf("[INFO] 执行工具: %s, ID: %s, skills:%s", toolCall.Name, toolCall.ID, skillName)
				}

				// 执行工具
				result, err := a.toolRegistry.Execute(ctx, toolCall)
				toolDurationMs := time.Since(toolStartTime).Milliseconds()
				resultContent := result.Content
				len_resultContext := a.countTokens(resultContent)
				excute_staus := false
				if err != nil {
					toolStep["success"] = false
					toolStep["error"] = err.Error()
					toolStep["output_summary"] = "工具执行失败"
					resultContent = fmt.Sprintf("工具执行错误: %v", err)
					a.fileLogger.Printf("[ERROR] 工具执行失败: %s, 错误: %v", toolCall.Name, err)
				} else {
					toolStep["success"] = true
					toolStep["output_summary"] = result.Content
					toolStep["duration_ms"] = toolDurationMs
					excute_staus = true
					if a.callback != nil {

						if len_resultContext < 300 {
							a.callback.OnAgentThinking(a.name, fmt.Sprintf("run tool[%s] succ,output:[%s]", toolCall.Name, resultContent), "rec")
						} else {
							a.callback.OnAgentThinking(a.name, fmt.Sprintf("run tool[%s] succ,output:[%s], more information in log file[len:%d]", toolCall.Name, resultContent, len_resultContext), "rec")
						}
					}
					a.fileLogger.Printf("[INFO] 工具执行成功: %s, 结果长度: %d,执行结果:%s", toolCall.Name, len_resultContext, truncate(resultContent, 1000))
				}

				toolStep["input_summary"] = formatToolCall(toolCall.Name, toolCall.Arguments, excute_staus)
				toolCallSummary = append(toolCallSummary, formatToolCall(toolCall.Name, toolCall.Arguments, excute_staus))

				callChain = append(callChain, toolStep)
				totalDurationMs += toolDurationMs

				if a.memory != nil {
					a.memory.SaveTaskLog(taskID, "TOOL_RESULT", fmt.Sprintf("Tool: %s\nResult:\n%s", toolCall.Name, truncate(resultContent, 300)))
				}

				// 添加工具结果 - 注意：只添加一次！
				toolResultMsg := map[string]interface{}{
					"role":         "tool",
					"tool_call_id": toolCall.ID,
					"name":         toolCall.Name,
					"content":      resultContent,
					"status":       excute_staus,
				}
				messages = append(messages, toolResultMsg)
				coldMessages = append(coldMessages, toolResultMsg)
				a.fileLogger.Printf("[INFO] 添加tool消息，tool_call_id: %s", toolCall.ID)

				if err := a.saveColdMessages(taskID, coldMessages); err != nil {
					a.fileLogger.Printf("[WARN] 保存 coldMessages 失败: %v", err)
				}

				allToolResults = append(allToolResults, fmt.Sprintf("%s: %s", toolCall.Name, truncate(resultContent, 2000)))
			}
			continue
		} else {
			finalOutput = response.Content
			a.fileLogger.Printf("[INFO] 获得最终响应，迭代次数: %d", iteration)

			if a.memory != nil {
				a.memory.SaveLog("task_complete",
					map[string]interface{}{
						"task_id":    taskID,
						"input":      input,
						"iterations": iteration,
					},
					finalOutput,
					map[string]interface{}{
						"agent":      a.name,
						"tool_calls": len(toolCalls),
					},
				)
			}
			event_status = "success"
			break
		}
	}

	endTime := time.Now()
	duration := endTime.Sub(startTime).Seconds()
	completed_reason := "task finish"
	if iteration == a.maxIterations {
		completed_reason = "reach the max iter "
	}

	finalDuration := endTime.Sub(startTime).Milliseconds()

	// 设置 MemoryEvent 的字段
	memoryEvent.EndTime = endTime
	memoryEvent.TotalDurationMs = finalDuration
	memoryEvent.FinalAnswer = finalOutput
	memoryEvent.CallChain, _ = json.Marshal(callChain)
	memoryEvent.TotalSteps = len(callChain)
	memoryEvent.SystemPrompt = systemPrompt
	memoryEvent.Status = event_status //success/failed/pending

	if event_status == "failed" {
		memoryEvent.ErrorMsg = completed_reason
	}
	// 输出类型判断
	memoryEvent.OutputType = a.detectOutputType(finalOutput)

	// 提取输出路径（如果生成了文件）
	if outputPath := a.extractOutputPath(finalOutput); outputPath != "" {
		memoryEvent.OutputPath = outputPath
		memoryEvent.OutputMeta, _ = json.Marshal(map[string]interface{}{
			"size": a.getFileSize(outputPath),
		})
	}

	// 提取见解
	insights := a.extractInsightsFromOutput(finalOutput, input)
	if len(insights) > 0 {
		memoryEvent.Insights, _ = json.Marshal(insights)
		memoryEvent.LearnNote = strings.Join(insights, "; ")
	}

	if a.memory != nil {
		if err := a.memory.SaveMemoryEvent(memoryEvent); err != nil {
			a.fileLogger.Printf("[ERROR] 保存记忆事件失败: %v", err)
		}
		a.memory.SaveTaskLog(taskID, "COMPLETE", fmt.Sprintf("%s\n Duration: %.2fs\nIterations: %d\nTools: %v\nFinal Output:\n%s",
			completed_reason, duration, iteration, toolCalls, finalOutput))

	}

	if a.callback != nil {

		summary := fmt.Sprintf("任务完成，输出长度: %d, 迭代次数: %d, 耗时: %.2fs", len(finalOutput), iteration, duration)
		if len(toolCalls) > 0 {
			toolSummary := strings.Join(toolCallSummary, " → ")
			summary += fmt.Sprintf(", 使用工具: %s", toolSummary)
		}
		a.callback.OnAgentThinking(a.name, completed_reason+summary, "completion")
	}

	a.fileLogger.Printf("[INFO] 任务 %s 完成，总耗时: %.2fs, 迭代次数: %d", taskID, duration, iteration)
	return finalOutput, nil
}

func (a *LLMAgent) detectOutputType(output string) string {
	// 检测是否包含代码块
	if strings.Contains(output, "```") {
		return "code"
	}

	// 检测是否包含文件路径
	if strings.Contains(output, ".md") || strings.Contains(output, ".txt") ||
		strings.Contains(output, ".json") || strings.Contains(output, ".yaml") {
		return "file"
	}

	// 默认文本
	return "text"
}

func (a *LLMAgent) extractOutputPath(output string) string {
	// 查找可能的文件路径模式
	patterns := []string{
		`文件已保存到[:：]\s*([^\s\n]+)`,
		`保存为[:：]\s*([^\s\n]+)`,
		`output[:：]\s*([^\s\n]+)`,
	}

	for _, pattern := range patterns {
		re := regexp.MustCompile(pattern)
		matches := re.FindStringSubmatch(output)
		if len(matches) > 1 {
			return matches[1]
		}
	}
	return ""
}

// getFileSize 获取文件大小
func (a *LLMAgent) getFileSize(filePath string) int64 {
	info, err := os.Stat(filePath)
	if err != nil {
		return 0
	}
	return info.Size()
}

// extractInsightsFromOutput 从输出中提取见解
func (a *LLMAgent) extractInsightsFromOutput(output, input string) []string {
	var insights []string

	// 定义提取规则
	insightPatterns := []struct {
		pattern string
		weight  float64
	}{
		{`(?:关键|重要)[^。]*[。！]`, 0.8},
		{`(?:结论|总结|概括)[^。]*[。！]`, 0.9},
		{`(?:建议|推荐)[^。]*[。！]`, 0.7},
		{`(?:注意|提醒)[^。]*[。！]`, 0.6},
		{`(?:经验|教训|心得)[^。]*[。！]`, 0.9},
		{`(?:方法|技巧)[^。]*[。！]`, 0.7},
	}

	// 按句子分割
	sentences := strings.Split(output, "。")
	for _, sentence := range sentences {
		sentence = strings.TrimSpace(sentence)
		if sentence == "" {
			continue
		}

		// 检查是否匹配任何模式
		for _, p := range insightPatterns {
			matched, _ := regexp.MatchString(p.pattern, sentence)
			if matched && len(sentence) > 10 && len(sentence) < 500 {
				insights = append(insights, sentence+"。")
				break
			}
		}
	}

	// 如果没有找到明显见解，尝试提取关键句子
	if len(insights) == 0 {
		// 按长度和位置提取
		lines := strings.Split(output, "\n")
		for i, line := range lines {
			line = strings.TrimSpace(line)
			if len(line) > 20 && len(line) < 200 && (i == len(lines)-1 || i == len(lines)-2) {
				// 取最后几行
				insights = append(insights, line)
				if len(insights) >= 2 {
					break
				}
			}
		}
	}

	// 限制数量
	if len(insights) > 3 {
		insights = insights[:3]
	}

	return insights
}

func (a *LLMAgent) PeriodicSummarize() {
	ticker := time.NewTicker(1 * time.Hour)
	defer ticker.Stop()

	for range ticker.C {
		if a.memory != nil {
			a.generateDailySummary()
		}
	}
}

// generateDailySummary 生成每日总结
func (a *LLMAgent) generateDailySummary() {
	today := time.Now().Format("2006-01-02")

	// 获取今天的所有事件
	var events []MemoryEvent
	startTime := time.Now().Truncate(24 * time.Hour)

	a.memory.db.Where("agent_name = ? AND created_at >= ?", a.name, startTime).
		Find(&events)

	if len(events) == 0 {
		return
	}

	// 统计
	totalEvents := len(events)
	successCount := 0
	var insights []string

	for _, event := range events {
		if event.Status == "success" {
			successCount++
		}

		var eventInsights []string
		if event.Insights != nil {
			json.Unmarshal(event.Insights, &eventInsights)
			insights = append(insights, eventInsights...)
		}
	}

	// 生成总结文本
	summary := fmt.Sprintf(`## 每日总结 (%s)

### 统计
- 总任务数: %d
- 成功数: %d
- 成功率: %.1f%%

### 关键洞察
%s

### 建议
%s
`,
		today,
		totalEvents,
		successCount,
		float64(successCount)/float64(totalEvents)*100,
		strings.Join(insights[:min(5, len(insights))], "\n- "),
		a.generateSuggestions(insights),
	)

	// 保存总结
	a.memory.SaveEventlog(summary, "daily_summary", []string{"summary", today}, "")
}

func (a *LLMAgent) generateSuggestions(insights []string) string {
	if len(insights) == 0 {
		return "暂无明确建议"
	}

	var suggestions []string

	// 分析洞察中的模式
	for _, insight := range insights {
		insightLower := strings.ToLower(insight)

		// 根据关键词生成建议
		if strings.Contains(insightLower, "性能") || strings.Contains(insightLower, "优化") {
			suggestions = append(suggestions, "建议关注性能优化，可以使用性能分析工具")
		}
		if strings.Contains(insightLower, "部署") || strings.Contains(insightLower, "配置") {
			suggestions = append(suggestions, "建议将部署流程自动化，减少手动操作")
		}
		if strings.Contains(insightLower, "错误") || strings.Contains(insightLower, "失败") {
			suggestions = append(suggestions, "建议增加错误处理和重试机制")
		}
		if strings.Contains(insightLower, "文档") || strings.Contains(insightLower, "注释") {
			suggestions = append(suggestions, "建议保持文档与代码同步更新")
		}
		if strings.Contains(insightLower, "测试") {
			suggestions = append(suggestions, "建议增加单元测试覆盖关键逻辑")
		}
		if strings.Contains(insightLower, "安全") {
			suggestions = append(suggestions, "建议进行安全审查，检查敏感信息")
		}
	}

	// 去重
	seen := make(map[string]bool)
	unique := make([]string, 0)
	for _, s := range suggestions {
		if !seen[s] {
			seen[s] = true
			unique = append(unique, s)
		}
	}

	if len(unique) == 0 {
		return "继续观察使用模式，积累更多数据后会有更精准的建议"
	}

	return strings.Join(unique, "\n- ")
}

// saveToKnowledgeBase 保存到知识库
func (a *LLMAgent) saveToKnowledgeBase(event *MemoryEvent, insights []string) {
	if a.memory == nil {
		return
	}

	// 生成知识标题
	title := event.UserQuestion
	if len(title) > 100 {
		title = title[:100]
	}

	// 为每条洞察创建知识条目
	for i, insight := range insights {
		knowledge := &Knowledge{
			AgentName:   a.name,
			KnowledgeID: fmt.Sprintf("know_%s_%d", event.SessionID, i),
			Title:       fmt.Sprintf("从「%s」学到的经验", truncate(event.UserQuestion, 30)),
			Summary:     insight,
			Content: fmt.Sprintf(
				"问题: %s\n\n洞察: %s\n\n完整回答: %s",
				event.UserQuestion,
				insight,
				truncate(event.FinalAnswer, 500),
			),
			Category:   "insight",
			SourceType: "extraction",
			SourceID:   fmt.Sprintf("%d", event.ID),
			Importance: 0.7,
			Tags:       a.extractTags(event.UserQuestion, insight),
		}

		if err := a.memory.SaveKnowledge(knowledge); err != nil {
			a.fileLogger.Printf("[ERROR] 保存知识失败: %v", err)
		}
	}
}

// extractTags 从内容和问题中提取标签
func (a *LLMAgent) extractTags(question, insight string) datatypes.JSON {
	tags := make(map[string]bool)

	// 定义常见技术栈关键词
	techKeywords := []string{
		"python", "go", "java", "javascript", "typescript", "rust",
		"docker", "kubernetes", "k8s", "aws", "azure", "gcp",
		"mysql", "postgresql", "mongodb", "redis",
		"react", "vue", "angular", "nodejs",
		"api", "rest", "graphql", "grpc",
	}

	// 定义主题关键词
	topicKeywords := []string{
		"部署", "配置", "调试", "优化", "性能", "安全",
		"测试", "文档", "代码", "架构", "设计",
	}

	// 从问题中提取
	text := strings.ToLower(question + " " + insight)
	for _, kw := range techKeywords {
		if strings.Contains(text, kw) {
			tags[kw] = true
		}
	}

	for _, kw := range topicKeywords {
		if strings.Contains(text, kw) {
			tags[kw] = true
		}
	}

	// 转换为切片
	tagList := make([]string, 0, len(tags))
	for tag := range tags {
		tagList = append(tagList, tag)
	}

	tagsJSON, _ := json.Marshal(tagList)
	return tagsJSON
}

func formatToolCall(toolName string, args map[string]interface{}, status bool) string {

	argsStr, _ := json.Marshal(args)
	switch toolName {
	case "list_dir", "list_directory":
		if path, ok := args["path"].(string); ok {
			return fmt.Sprintf("list(%s)[%t]", path, status)
		}
		return fmt.Sprintf("list(%s)[%t]", truncate(string(argsStr), 100), status)

	case "read_file":
		if path, ok := args["path"].(string); ok {
			return fmt.Sprintf("read(%s)[%t]", path, status)
		}
		return fmt.Sprintf("read(%s)[%t]", truncate(string(argsStr), 100), status)

	case "write_file":
		if path, ok := args["path"].(string); ok {
			return fmt.Sprintf("write(%s)[%t]", path, status)
		}
		return fmt.Sprintf("write(%s)[%t]", truncate(string(argsStr), 100), status)

	case "cli", "execute_command":
		if cmd, ok := args["command"].(string); ok {
			// 简化命令显示
			shortCmd := cmd
			if len(shortCmd) > 200 {
				shortCmd = truncate(shortCmd, 180) + "..."
			}
			return fmt.Sprintf("cmd(%s)[%t]", shortCmd, status)
		}
		return fmt.Sprintf("cli(%s)[%t]", truncate(string(argsStr), 100), status)

	default:
		return fmt.Sprintf("%s(%s)[%t]", toolName, truncate(string(argsStr), 100), status)
	}
}

// simplifyCommand 简化命令显示
func simplifyCommand(cmd string) string {
	// 截断过长命令
	if len(cmd) > 40 {
		cmd = cmd[:37] + "..."
	}

	// 简化常见的命令模式
	cmd = strings.ReplaceAll(cmd, "\n", " ")
	cmd = strings.ReplaceAll(cmd, "  ", " ")

	return cmd
}

func formatMessages2(messages []map[string]interface{}, lastLoggedMsgCount int) string {
	var result strings.Builder
	for i, msg := range messages {
		role, _ := msg["role"].(string)
		content, _ := msg["content"].(string)

		// 截断过长的内容
		if len(messages) > 2 {
			content = truncate(content, 200)
		}
		if i >= lastLoggedMsgCount {
			result.WriteString(fmt.Sprintf("\n  [%d] %s: %s", i+1, role, content))

			// 如果有tool_calls，也记录
			if toolCalls, ok := msg["tool_calls"]; ok && toolCalls != nil {
				result.WriteString(fmt.Sprintf(" %v", toolCalls))
			}
		}
	}
	return result.String()
}

func extractKeyPoints(output string) []string {
	points := []string{}

	// 按句子分割
	sentences := strings.Split(output, "。")
	for _, s := range sentences {
		s = strings.TrimSpace(s)
		if s == "" {
			continue
		}

		// 检查是否包含关键指示词
		indicators := []string{"关键", "重要", "结论", "总结", "因此", "所以",
			"建议", "推荐", "注意", "insight", "conclusion", "key point"}

		for _, ind := range indicators {
			if strings.Contains(strings.ToLower(s), strings.ToLower(ind)) {
				if len(s) > 150 {
					s = s[:150] + "..."
				}
				points = append(points, s)
				break
			}
		}
	}

	// 如果没有找到带指示词的句子，取前2句作为关键点
	if len(points) == 0 {
		sentences := strings.Split(output, "。")
		for i, s := range sentences {
			if i >= 2 {
				break
			}
			s = strings.TrimSpace(s)
			if s != "" {
				if len(s) > 150 {
					s = s[:150] + "..."
				}
				points = append(points, s)
			}
		}
	}

	return points
}

type TaskSummary struct {
	TaskID        string                 `json:"task_id"`
	StartTime     time.Time              `json:"start_time"`
	EndTime       time.Time              `json:"end_time"`
	Duration      float64                `json:"duration_seconds"`
	AgentName     string                 `json:"agent_name"`
	UserName      string                 `json:"user_name"` // 用户名，默认为"user"
	TaskDesc      string                 `json:"task_desc"`
	Status        string                 `json:"status"` // success, failed, partial
	InputPreview  string                 `json:"input_preview"`
	Conclusion    string                 `json:"conclusion"`         // 核心结论/输出摘要
	KeyPoints     []string               `json:"key_points"`         // 关键点列表
	ToolsUsed     []string               `json:"tools_used"`         // 使用的工具
	KeyPaths      []string               `json:"key_paths"`          // 关键路径/文件
	Iterations    int                    `json:"iterations"`         // 迭代次数
	Feedback      *Feedback              `json:"feedback,omitempty"` // 用户反馈
	TokenEstimate int                    `json:"token_estimate"`     // 估算token
	Metadata      map[string]interface{} `json:"metadata,omitempty"`
}

type Feedback struct {
	Rating     int       `json:"rating"`      // 1-5星评分
	IsPositive bool      `json:"is_positive"` // true=好评, false=差评
	Comment    string    `json:"comment"`     // 用户评论
	Timestamp  time.Time `json:"timestamp"`
	Method     string    `json:"method"` // 使用的方法/工具序列
}

type UserPreferenceSection struct {
	UserName         string             `json:"user_name"`
	LastUpdated      time.Time          `json:"last_updated"`
	PreferredTools   []ToolPreference   `json:"preferred_tools"`   // 工具偏好
	PreferredMethods []MethodPreference `json:"preferred_methods"` // 方法偏好
	CommonTopics     map[string]int     `json:"common_topics"`     // 常见主题及频次
	FeedbackStats    FeedbackStats      `json:"feedback_stats"`
	SummaryFrequency string             `json:"summary_frequency"` // 总结频率: daily, weekly, monthly
}

type ToolPreference struct {
	Name        string    `json:"name"`
	SuccessRate float64   `json:"success_rate"` // 成功率
	AvgRating   float64   `json:"avg_rating"`   // 平均评分
	UseCount    int       `json:"use_count"`
	LastUsed    time.Time `json:"last_used"`
}

type MethodPreference struct {
	Description  string    `json:"description"`
	ToolSequence []string  `json:"tool_sequence"`
	SuccessRate  float64   `json:"success_rate"`
	AvgRating    float64   `json:"avg_rating"`
	UseCount     int       `json:"use_count"`
	LastUsed     time.Time `json:"last_used"`
}

type FeedbackStats struct {
	TotalFeedbacks int     `json:"total_feedbacks"`
	PositiveCount  int     `json:"positive_count"`
	NegativeCount  int     `json:"negative_count"`
	AvgRating      float64 `json:"avg_rating"`
}

func (a *LLMAgent) buildSystemPrompt(taskID, currentQuestion string) string {
	var prompt strings.Builder
	now := time.Now()
	// 1. Core identity - clear and concise
	prompt.WriteString(fmt.Sprintf(`now is %s
your name is %s, You are agent, a helpful AI assistant specialized in your domain.
`, now.Format("2006-01-02 15:04:05"), a.name))
	// 2. Runtime information
	prompt.WriteString("## Runtime\n")
	storage := filepath.Join(a.workspace, "storage")
	prompt.WriteString(fmt.Sprintf("Workspace: %s\n", a.workspace))
	prompt.WriteString(fmt.Sprintf("Storage directory: %s\n", storage))

	// 核心规则（AI 100% 理解）
	prompt.WriteString(fmt.Sprintf("IMPORTANT: All generated content MUST be saved inside the `%s` directory.\n", storage))
	prompt.WriteString("This includes: code files, scripts, reports, documents, outputs, and all miscellaneous files.\n")

	if a.hasMemory && a.memory != nil {
	}

	// Skills directory info
	if a.skillsLoader != nil {
		skillPath := filepath.Join(a.workspace, "skills")
		prompt.WriteString(fmt.Sprintf("Skills: %s/\n", skillPath))
		skillsSummary := a.skillsLoader.BuildSkillsSummary()
		if skillsSummary != "" {
			// Extract just the text part, not the XML
			if idx := strings.Index(skillsSummary, "<skills>"); idx > 0 {
				skillsSummary = skillsSummary[:idx]
			}
			prompt.WriteString(skillsSummary)
			prompt.WriteString("\n")
		}
	}
	prompt.WriteString("\n")

	// 3. Platform policy (optional, based on OS)
	if runtime.GOOS == "windows" {
		prompt.WriteString(`## Platform Policy (Windows)
- You are running on Windows. Do not assume GNU tools like ` + "`grep`, `sed`,`pwd`, or `awk`  " + ` exist.
- Prefer using the built-in file tools when possible.

`)
	} else {
		prompt.WriteString(`## Platform Policy (POSIX)
- You are running on a POSIX system. Standard shell tools are available.
`)
	}
	// 4. Agent guidelines - clear rules of behavior
	prompt.WriteString(`## Guidelines
- State your intent before using tools, but NEVER predict results before receiving them.
- Ask for clarification when the request is ambiguous.
- Reply directly with text for conversations. Only use tools when necessary.
- **When task is complete, provide final answer and stop**
- **When writing code files, output as pure JSON with "path" and "content" fields. Escape all special characters (quotes, newlines, backslashes). No markdown code blocks or extra text.Do NOT include comments in the code. Prioritize runnable code.No fancy formatting, decorative symbols, or ASCII art**
- **若有代码只生成代码，省略注释**
\`)

	// 5. Available tools (if any) - compact format like nanobot's skills section
	if a.toolRegistry != nil && len(a.toolRegistry.GetDefinitions()) > 0 {
		prompt.WriteString("## Available Tools\n\n")

		toolDefs := a.toolRegistry.GetDefinitions()
		for _, def := range toolDefs {
			if fn, ok := def["function"].(map[string]interface{}); ok {
				name := fn["name"].(string)
				desc := fn["description"].(string)
				prompt.WriteString(fmt.Sprintf("- **%s**: %s\n", name, desc))

				// Add parameters in a compact format
				// if params, ok := fn["parameters"].(map[string]interface{}); ok {
				// 	if props, ok := params["properties"].(map[string]interface{}); ok && len(props) > 0 {
				// 		required, _ := params["required"].([]interface{})
				// 		requiredSet := make(map[string]bool)
				// 		for _, r := range required {
				// 			if reqStr, ok := r.(string); ok {
				// 				requiredSet[reqStr] = true
				// 			}
				// 		}

				// 		paramStrs := []string{}
				// 		for name, prop := range props {
				// 			if p, ok := prop.(map[string]interface{}); ok {
				// 				desc, _ := p["description"].(string)
				// 				if requiredSet[name] {
				// 					paramStrs = append(paramStrs, fmt.Sprintf("`%s` (required): %s", name, desc))
				// 				} else {
				// 					paramStrs = append(paramStrs, fmt.Sprintf("`%s`: %s", name, desc))
				// 				}
				// 			}
				// 		}
				// 		if len(paramStrs) > 0 {
				// 			prompt.WriteString(fmt.Sprintf("  - Parameters: %s\n", strings.Join(paramStrs, "; ")))
				// 		}
				// 	}
				// }
			}
		}
		prompt.WriteString("\n")
	}

	// 6. Memory context (like nanobot's Memory section)
	if a.hasMemory && a.memory != nil {
		memoryCtx := a.memory.GetMemoryContext("", "", currentQuestion)
		if memoryCtx != "" {
			prompt.WriteString("## Memory\n\n")
			prompt.WriteString(memoryCtx)
			prompt.WriteString("\n")
		}
	}

	// 7. Skills summary (if any)
	if a.skillsLoader != nil && len(a.skillsLoader.skills) > 0 {
		prompt.WriteString("## Available Skills\n\n")

		// 按类别分组
		alwaysSkills := make([]string, 0)
		normalSkills := make([]string, 0)

		for name, skill := range a.skillsLoader.skills {
			if skill.Metadata.Always {
				alwaysSkills = append(alwaysSkills, name)
			} else {
				normalSkills = append(normalSkills, name)
			}
		}

		// if len(alwaysSkills) > 0 {
		// 	prompt.WriteString("### Always Available\n")
		// 	for _, name := range alwaysSkills {
		// 		skill := a.skillsLoader.skills[name]
		// 		prompt.WriteString(fmt.Sprintf("- **%s**: %s\n", name, skill.Metadata.Description))
		// 	}
		// 	prompt.WriteString("\n")
		// }

		// if len(normalSkills) > 0 {
		// 	prompt.WriteString("### Other Skills\n")
		// 	prompt.WriteString(strings.Join(normalSkills, ", "))
		// 	prompt.WriteString("\n\n")
		// }

		// 技能使用说明
		prompt.WriteString("To use a skill, read its documentation with `read_file` then use `use_skill`.\n\n")
		if a.callback != nil {
			a.callback.OnAgentThinking(a.name, fmt.Sprintf("build skills[%s] prompt", strings.Join(normalSkills, ", ")), "rec")
		}
	} else {
		log.Println("have no skills ##########")
	}

	// 8. Simple tool usage examples - only a few, compact
	if a.toolRegistry != nil {
		prompt.WriteString(`## Tool Examples

`)
		if _, ok := a.toolRegistry.Get("read_file"); ok {
			prompt.WriteString(`Read a file:
{
  "tool_calls": [{"id": "call_1", "name": "read_file", "arguments": {"path": "example.txt"}}]
}

`)
		}
		if _, ok := a.toolRegistry.Get("write_file"); ok {
			prompt.WriteString(`Write a file:
{
  "tool_calls": [{"id": "call_1", "name": "write_file", "arguments": {"path": "result.txt", "content": "text"}}]
}

`)
		}
		if _, ok := a.toolRegistry.Get("list_dir"); ok {
			prompt.WriteString(`List directory with options:
{
  "tool_calls": [{
    "id": "call_1", 
    "name": "list_dir", 
    "arguments": {
      "path": ".", 
      "depth": 2, 
      "detail": true,
      "pattern": "*.go",
      "sort_by": "size"
    }
  }]
}

`)
		}
	}

	// 9. Final instruction - simple and direct
	prompt.WriteString(`## Response Format
You can respond with:
1. **Plain text** - Direct answer to the user
2. **Tool calls** - JSON format shown above

Begin.
`)

	return prompt.String()
}

func (a *LLMAgent) getWorkspaceStructure() (string, error) {
	if a.workspace == "" {
		return "", fmt.Errorf("workspace not set")
	}

	// 检查工作空间是否存在
	if _, err := os.Stat(a.workspace); os.IsNotExist(err) {
		return "", err
	}

	var result strings.Builder
	result.WriteString("📁 Workspace Structure (up to 3 levels deep, max 10 items per directory)\n")
	result.WriteString(strings.Repeat("─", 10) + "\n")

	// 构建目录树，深度为4层，每层最多10个项目
	err := a.buildDirectoryTree(&result, a.workspace, "", 0, 3, 10)
	if err != nil {
		return "", err
	}
	return result.String(), nil
}

func (a *LLMAgent) buildDirectoryTree(w *strings.Builder, currentPath string, prefix string, currentDepth, maxDepth, maxItems int) error {
	if currentDepth >= maxDepth {
		// 在最大深度处显示省略号
		if currentDepth == maxDepth {
			fmt.Fprintf(w, "%s└── ... (max depth %d reached, use list_dir with depth>%d to see deeper)\n",
				prefix, maxDepth, maxDepth)
		}
		return nil
	}

	entries, err := os.ReadDir(currentPath)
	if err != nil {
		// 如果是权限错误，显示提示但不中断
		if os.IsPermission(err) {
			fmt.Fprintf(w, "%s└── [permission denied]\n", prefix)
			return nil
		}
		return err
	}

	// 过滤和排序
	filtered := make([]os.DirEntry, 0)
	for _, entry := range entries {
		name := entry.Name()
		// 跳过隐藏文件和目录（以.开头）
		if strings.HasPrefix(name, ".") {
			continue
		}
		// 跳过常见的临时/依赖目录
		skipDirs := map[string]bool{
			"node_modules": true,
			"vendor":       true,
			".git":         true,
			"__pycache__":  true,
			"dist":         true,
			"build":        true,
			"tmp":          true,
			"temp":         true,
			"cache":        true,
		}
		if skipDirs[name] {
			continue
		}
		filtered = append(filtered, entry)
	}

	// 排序：目录在前，文件在后，按名称排序
	sort.Slice(filtered, func(i, j int) bool {
		if filtered[i].IsDir() != filtered[j].IsDir() {
			return filtered[i].IsDir() // 目录排在前面
		}
		return filtered[i].Name() < filtered[j].Name()
	})

	// 限制显示数量
	totalItems := len(filtered)
	if totalItems > maxItems {
		// 只显示前 maxItems 个
		filtered = filtered[:maxItems]

		for i, entry := range filtered {
			isLast := i == len(filtered)-1
			connector := "├── "
			if isLast {
				connector = "└── "
			}

			name := entry.Name()
			if entry.IsDir() {
				fmt.Fprintf(w, "%s%s📁 %s/\n", prefix, connector, name)

				// 递归进入子目录
				subPath := filepath.Join(currentPath, name)
				var subPrefix string
				if isLast {
					subPrefix = prefix + "    "
				} else {
					subPrefix = prefix + "│   "
				}

				a.buildDirectoryTree(w, subPath, subPrefix, currentDepth+1, maxDepth, maxItems)
			} else {
				// 获取文件大小
				info, err := entry.Info()
				size := ""
				if err == nil {
					size = " (" + formatSize(info.Size()) + ")"
				}
				fmt.Fprintf(w, "%s%s📄 %s%s\n", prefix, connector, name, size)
			}
		}

		// 显示省略号，说明还有更多项目
		remaining := totalItems - maxItems
		fmt.Fprintf(w, "%s└── ... (%d more items not shown, use list_dir to see all)\n",
			prefix, remaining)

	} else {
		// 正常显示所有项目
		for i, entry := range filtered {
			isLast := i == len(filtered)-1
			connector := "├── "
			if isLast {
				connector = "└── "
			}

			name := entry.Name()
			if entry.IsDir() {
				fmt.Fprintf(w, "%s%s📁 %s/\n", prefix, connector, name)

				// 递归进入子目录
				subPath := filepath.Join(currentPath, name)
				var subPrefix string
				if isLast {
					subPrefix = prefix + "    "
				} else {
					subPrefix = prefix + "│   "
				}

				a.buildDirectoryTree(w, subPath, subPrefix, currentDepth+1, maxDepth, maxItems)
			} else {
				// 获取文件大小
				info, err := entry.Info()
				size := ""
				if err == nil {
					size = " (" + formatSize(info.Size()) + ")"
				}
				fmt.Fprintf(w, "%s%s📄 %s%s\n", prefix, connector, name, size)
			}
		}
	}
	return nil
}

func (a *LLMAgent) callLLM(ctx context.Context, messages []map[string]interface{}) (*AgentResponse, error) {
	maxRetries := 3
	var lastErr error

	// 添加一个函数来重置连接
	resetConnection := func() {
		if a.httpClient != nil {
			if transport, ok := a.httpClient.Transport.(*http.Transport); ok {
				transport.CloseIdleConnections()
				a.fileLogger.Printf("[DEBUG] 已关闭空闲连接")
			}
		}
	}
	errorFeedback := ""
	for retry := 0; retry < maxRetries; retry++ {

		if retry > 0 {
			resetConnection()
			// 增加退避时间，让服务端有时间恢复
			backoff := time.Duration(1<<uint(retry)) * 2 * time.Second
			if backoff > 30*time.Second {
				backoff = 30 * time.Second
			}
			a.fileLogger.Printf("[INFO] 等待 %v 后重试", backoff)
			time.Sleep(backoff)
		}

		// 为每次重试创建新的超时 context
		timeoutCtx, cancel := context.WithTimeout(ctx, 120*time.Second)

		requestBody := map[string]interface{}{
			"model":       a.modelConfig.ModelName,
			"messages":    messages,
			"temperature": a.temperature,
			"max_tokens":  a.maxTokens,
		}

		// 如果有工具，添加tools字段
		if a.toolRegistry != nil && len(a.toolRegistry.GetDefinitions()) > 0 {
			requestBody["tools"] = a.toolRegistry.GetDefinitions()
		}
		if errorFeedback != "" {
			requestBody["important"] = errorFeedback
		}

		jsonData, err := json.Marshal(requestBody)
		if err != nil {
			cancel()
			return nil, fmt.Errorf("序列化请求失败: %w", err)
		}

		a.fileLogger.Printf("[DEBUG] 请求体大小: %d bytes, 重试次数: %d,请求体: %s", len(jsonData), retry, jsonData)

		req, err := http.NewRequestWithContext(timeoutCtx, "POST", a.modelConfig.BaseURL+"/chat/completions", bytes.NewBuffer(jsonData))
		if err != nil {
			cancel()
			return nil, fmt.Errorf("创建请求失败: %w", err)
		}

		req.Header.Set("Content-Type", "application/json")
		req.Header.Set("Authorization", "Bearer "+a.modelConfig.APIKey)
		req.Header.Set("X-Retry-Count", fmt.Sprintf("%d", retry))
		req.Header.Set("User-Agent", "MultiAgentSystem/1.0")
		// 移除 Connection: close，让 HTTP 客户端自己管理连接

		startTime := time.Now()
		if a.callback != nil {
			a.callback.OnAgentThinking(a.name, fmt.Sprintf("begin %dth sub iteration", retry+1), "rec")
		}

		a.fileLogger.Printf("begin sub iteration-call")
		resp, err := a.httpClient.Do(req)
		elapsed := time.Since(startTime)

		if err != nil {
			cancel()
			lastErr = err
			if errors.Is(err, context.DeadlineExceeded) {
				a.fileLogger.Printf("[WARN] 第 %d 次请求超时 (耗时: %v)，等待后重试", retry+1, elapsed)
			} else if strings.Contains(err.Error(), "forcibly closed") ||
				strings.Contains(err.Error(), "connection reset") {
				a.fileLogger.Printf("[WARN] 第 %d 次请求连接被重置 (耗时: %v)，等待后重试", retry+1, elapsed)
				resetConnection()
			} else {
				a.fileLogger.Printf("[ERROR] 第 %d 次请求失败: %v (耗时: %v)", retry+1, err, elapsed)
			}

			if a.callback != nil {
				a.callback.OnAgentThinking(a.name, fmt.Sprintf("[WARN] 第 %d 次请求失败 (耗时: %v)，error:%v", retry+1, elapsed, lastErr), "rec")
			}
			continue
		}

		// 读取响应体
		body, err := io.ReadAll(resp.Body)
		resp.Body.Close()
		cancel()

		if err != nil {
			a.fileLogger.Printf("读取响应失败: %v", err)
			lastErr = fmt.Errorf("读取响应失败: %w", err)
			if a.callback != nil {
				a.callback.OnAgentThinking(a.name, fmt.Sprintf("读取响应失败: %v", err), "rec")
			}

			if strings.Contains(err.Error(), "forcibly closed") ||
				strings.Contains(err.Error(), "connection reset") {
				resetConnection()
			}
			continue
		}

		cleanBody := CleanBytes(body)

		if a.callback != nil {
			a.callback.OnAgentThinking(a.name, fmt.Sprintf("rcv llm response,from %d call llm ", retry+1), "rec")
		}
		a.fileLogger.Printf("++++++")
		a.fileLogger.Printf("[llm response] %s", cleanBody)
		a.fileLogger.Printf("------")

		// 检查 HTTP 状态码
		if resp.StatusCode != http.StatusOK {
			if resp.StatusCode >= 500 || resp.StatusCode == 429 {
				lastErr = fmt.Errorf("API返回错误状态码: %d, 响应: %s", resp.StatusCode, string(cleanBody))
				a.fileLogger.Printf("[WARN] 第 %d 次请求返回状态码 %d，等待后重试", retry+1, resp.StatusCode)

				if a.callback != nil {
					a.callback.OnAgentThinking(a.name, fmt.Sprintf("[WARN] 第 %d 次请求返回状态码 %d", retry+1, resp.StatusCode), "rec")
				}
				continue
			}
			return nil, fmt.Errorf("API返回错误状态码: %d, 响应: %s", resp.StatusCode, string(cleanBody))
		}

		// 解析响应
		var response struct {
			Choices []struct {
				Message struct {
					Content   string `json:"content"`
					ToolCalls []struct {
						ID       string `json:"id"`
						Type     string `json:"type"`
						Function struct {
							Name      string `json:"name"`
							Arguments string `json:"arguments"`
						} `json:"function"`
					} `json:"tool_calls"`
				} `json:"message"`
				FinishReason string `json:"finish_reason"`
			} `json:"choices"`
			Error *struct {
				Message string `json:"message"`
			} `json:"error,omitempty"`
		}

		if err := json.Unmarshal(cleanBody, &response); err != nil {
			lastErr = fmt.Errorf("解析响应失败: %w, 原始响应: %s", err, string(cleanBody))

			a.fileLogger.Printf("[ERROR] 第 %d 次请求解析响应失败: %v", retry+1, err)
			if a.callback != nil {
				a.callback.OnAgentThinking(a.name, fmt.Sprintf("[ERROR] llm response parse fail: %v", err), "rec")
			}
			continue
		}

		if response.Error != nil {
			lastErr = fmt.Errorf("API错误: %s", response.Error.Message)
			a.fileLogger.Printf("[ERROR] 第 %d 次请求返回 API 错误: %s", retry+1, response.Error.Message)
			if a.callback != nil {
				a.callback.OnAgentThinking(a.name, fmt.Sprintf("[ERROR] API错误: %s", response.Error.Message), "rec")
			}
			return nil, lastErr
		}

		if len(response.Choices) == 0 {
			lastErr = errors.New("LLM返回空响应")
			a.fileLogger.Printf("[WARN] 第 %d 次请求返回空响应", retry+1)
			if a.callback != nil {
				a.callback.OnAgentThinking(a.name, "[WARN] LLM返回空响应", "rec")
			}
			continue
		}

		choice := response.Choices[0]
		a.fileLogger.Printf("choice:%v", choice)
		if choice.FinishReason == "length" {
			a.fileLogger.Printf("[WARN] LLM 响应因 token 限制被截断")
			errorFeedback = "代码尽量精简不要被截断"
			if a.callback != nil {
				a.callback.OnAgentThinking(a.name, "code truncated by server,retry call llm", "rec")
			}

		}
		// 处理工具调用
		var toolCalls []ToolCall
		var parseErrors []string

		for _, tc := range choice.Message.ToolCalls {
			var args map[string]interface{}
			argsStr := tc.Function.Arguments
			// cleaned := cleanJSONString(argsStr)
			if a.callback != nil {
				a.callback.OnAgentThinking(a.name, fmt.Sprintf("will use tool[%s] in response toolcalls", tc.Function.Name), "rec")
			}

			if err := json.Unmarshal([]byte(argsStr), &args); err != nil {
				if a.callback != nil {
					a.callback.OnAgentThinking(a.name, fmt.Sprintf("%s arg parse fail", tc.Function.Name), "rec")
				}
				a.fileLogger.Printf("argsStr:%s", argsStr)
				if tc.Function.Name == "write_file" {
					parsedArgs, parseErr := parseWriteFileArgs(argsStr)
					if parseErr != nil {
						errMsg := fmt.Sprintf("工具 %s 参数解析失败: %v", tc.Function.Name, parseErr)
						a.fileLogger.Printf("[ERROR] %s", errMsg)
						parseErrors = append(parseErrors, errMsg)
						if a.callback != nil {
							a.callback.OnAgentThinking(a.name, errMsg, "rec")
						}
						continue
					}
					args = parsedArgs
				} else {

					errMsg := fmt.Sprintf("工具 %s 参数解析失败: %v, 原始参数: %s", tc.Function.Name, err, argsStr)
					a.fileLogger.Printf("[ERROR] %s", errMsg)
					parseErrors = append(parseErrors, errMsg)
					if a.callback != nil {
						a.callback.OnAgentThinking(a.name, errMsg, "rec")
					}
					continue
				}
			}

			toolCalls = append(toolCalls, ToolCall{
				ID:        tc.ID,
				Name:      tc.Function.Name,
				Arguments: args,
			})
		}

		// 如果有解析错误，将错误反馈给 LLM，让它在下一轮修正
		if len(parseErrors) > 0 {
			a.fileLogger.Printf("[WARN] 检测到 %d 个工具调用参数解析错误，请LLM 修正", len(parseErrors))

			// 构建错误反馈消息
			errorFeedback = "工具调用参数解析失败，请修正后重试:\n" + strings.Join(parseErrors, "\n")
			errorFeedback += "\n\n请确保:\n"
			errorFeedback += "1. 所有参数都是有效的 JSON 格式\n"
			errorFeedback += "2. 字符串中的特殊字符（引号、换行等）已正确转义\n"
			errorFeedback += "3. write_file 工具必须包含 path 和 content 参数\n"
			errorFeedback += "4. append 参数应该是布尔值 (true/false)\n"

			a.fileLogger.Printf("[INFO] 已将参数解析错误反馈给 LLM，准备重试")
			// 继续循环，让 LLM 修正参数
			lastErr = fmt.Errorf("工具调用参数解析错误: %s", strings.Join(parseErrors, "; "))
			continue
		} else {
			errorFeedback = ""
		}

		// 如果有工具调用但没有解析错误，正常返回
		if len(toolCalls) > 0 {
			a.fileLogger.Printf("[INFO] 成功解析 %d 个工具调用", len(toolCalls))
			return &AgentResponse{
				Content:      choice.Message.Content,
				ToolCalls:    toolCalls,
				FinishReason: choice.FinishReason,
			}, nil
		}

		// 没有工具调用，直接返回内容
		a.fileLogger.Printf("[INFO] 成功获取LLM响应，内容长度: %d", len(choice.Message.Content))
		return &AgentResponse{
			Content:      choice.Message.Content,
			ToolCalls:    nil,
			FinishReason: choice.FinishReason,
		}, nil
	}

	return nil, fmt.Errorf("达到最大重试次数: %v", lastErr)
}

func parseWriteFileArgs(rawStr string) (map[string]interface{}, error) {
	result := make(map[string]interface{})

	// 默认值
	result["append"] = false
	result["encoding"] = "utf-8"

	if rawStr == "" {
		return nil, fmt.Errorf("参数为空")
	}

	log.Printf("[DEBUG] 开始解析 write_file 参数，原始字符串长度: %d", len(rawStr))

	// 策略1: 直接解析整个字符串为 JSON
	var rawParams map[string]interface{}
	if err := json.Unmarshal([]byte(rawStr), &rawParams); err == nil {
		log.Printf("[INFO] 成功直接解析 JSON")
		return extractParamsFromMap(rawParams)
	}

	// 策略2: 尝试处理转义的 JSON 字符串
	unescaped := strings.ReplaceAll(rawStr, `\"`, `"`)
	if err := json.Unmarshal([]byte(unescaped), &rawParams); err == nil {
		log.Printf("[INFO] 成功解析去除转义后的 JSON")
		return extractParamsFromMap(rawParams)
	}

	// 策略3: 如果字符串被引号包围，尝试去除外层引号
	if strings.HasPrefix(rawStr, "\"") && strings.HasSuffix(rawStr, "\"") {
		unquoted, err := strconv.Unquote(rawStr)
		if err == nil {
			if err := json.Unmarshal([]byte(unquoted), &rawParams); err == nil {
				log.Printf("[INFO] 成功解析去除外层引号后的 JSON")
				return extractParamsFromMap(rawParams)
			}
		}
	}

	// 策略4: 使用更智能的手动解析方式
	log.Printf("[WARN] JSON 解析失败，使用手动提取方式")
	return parseManually(rawStr, result)
}

// parseManually 手动解析参数，支持复杂的 content 内容
func parseManually(rawStr string, result map[string]interface{}) (map[string]interface{}, error) {
	// 提取 path
	path, err := extractFieldSmart(rawStr, "path")
	if err != nil {
		return nil, fmt.Errorf("提取 path 失败: %w", err)
	}
	result["path"] = path
	log.Printf("[DEBUG] 提取到 path: %s", path)

	// 提取 append
	appendMode, err := extractBoolFieldSmart(rawStr, "append")
	if err == nil {
		result["append"] = appendMode
		log.Printf("[DEBUG] 提取到 append: %v", appendMode)
	}

	// 提取 content - 使用智能提取方法
	content, err := extractContentField(rawStr)
	if err != nil {
		return nil, fmt.Errorf("提取 content 失败: %w", err)
	}
	result["content"] = content
	log.Printf("[DEBUG] 提取到 content，长度: %d", len(content))

	// 提取可选参数
	if encoding, err := extractFieldSmart(rawStr, "encoding"); err == nil {
		result["encoding"] = encoding
	}
	if format, err := extractFieldSmart(rawStr, "format"); err == nil {
		result["format"] = format
	}

	return result, nil
}

// extractContentField 专门用于提取 content 字段，因为它的内容可能非常复杂
func extractContentField(rawStr string) (string, error) {
	// 找到 "content": 的位置
	contentKey := `"content":`
	idx := strings.Index(rawStr, contentKey)
	if idx == -1 {
		// 尝试单引号
		contentKey = `'content':`
		idx = strings.Index(rawStr, contentKey)
	}

	if idx == -1 {
		return "", fmt.Errorf("未找到 content 字段")
	}

	// 找到 content 值的开始位置（跳过冒号和空白）
	start := idx + len(contentKey)
	for start < len(rawStr) && (rawStr[start] == ' ' || rawStr[start] == '\t' || rawStr[start] == '\n') {
		start++
	}

	if start >= len(rawStr) {
		return "", fmt.Errorf("content 值开始位置无效")
	}

	// 检查值的类型
	if rawStr[start] == '"' {
		// 字符串类型，找到匹配的结束引号（考虑转义）
		return extractQuotedString(rawStr, start)
	} else if rawStr[start] == '\'' {
		// 单引号字符串
		return extractQuotedStringSingle(rawStr, start)
	} else {
		// 可能是数字、布尔值或其他类型，但 content 通常是字符串
		return "", fmt.Errorf("content 值不是字符串类型")
	}
}

func extractQuotedString(s string, startIdx int) (string, error) {
	if startIdx >= len(s) || s[startIdx] != '"' {
		return "", fmt.Errorf("不是有效的双引号字符串")
	}

	end := startIdx + 1
	escaped := false
	foundEnd := false

	for end < len(s) {
		if escaped {
			escaped = false
			end++
			continue
		}

		if s[end] == '\\' {
			escaped = true
			end++
			continue
		}

		if s[end] == '"' {
			foundEnd = true
			break
		}
		end++
	}

	var value string
	if foundEnd {
		value = s[startIdx+1 : end]
	} else {
		// 被截断了，取从开始到末尾的所有内容
		value = s[startIdx+1:]
		value = value + "... (JSON被截断)"
	}

	value = unescapeString(value)
	return value, nil
}

// extractQuotedStringSingle 提取单引号字符串
func extractQuotedStringSingle(s string, startIdx int) (string, error) {
	if startIdx >= len(s) || s[startIdx] != '\'' {
		return "", fmt.Errorf("不是有效的单引号字符串")
	}

	end := startIdx + 1
	escaped := false
	foundEnd := false

	for end < len(s) {
		if escaped {
			escaped = false
			end++
			continue
		}

		if s[end] == '\\' {
			escaped = true
			end++
			continue
		}

		if s[end] == '\'' {
			foundEnd = true
			break
		}
		end++
	}

	var value string
	if foundEnd {
		value = s[startIdx+1 : end]
	} else {
		// 被截断了，取从开始到末尾的所有内容
		value = s[startIdx+1:]
		value = value + "... (JSON被截断)"
	}

	value = unescapeString(value)
	return value, nil
}

func extractFieldSmart(rawStr, fieldName string) (string, error) {
	// 构建字段键的搜索模式
	fieldKey := fmt.Sprintf(`"%s":`, fieldName)
	idx := strings.Index(rawStr, fieldKey)
	if idx == -1 {
		// 尝试单引号
		fieldKey = fmt.Sprintf(`'%s':`, fieldName)
		idx = strings.Index(rawStr, fieldKey)
	}

	if idx == -1 {
		return "", fmt.Errorf("未找到字段: %s", fieldName)
	}

	// 找到值的开始位置
	start := idx + len(fieldKey)
	for start < len(rawStr) && (rawStr[start] == ' ' || rawStr[start] == '\t' || rawStr[start] == '\n') {
		start++
	}

	if start >= len(rawStr) {
		return "", fmt.Errorf("字段值位置无效")
	}

	// 如果值以引号开头，提取引号内的内容
	if rawStr[start] == '"' {
		return extractQuotedString(rawStr, start)
	} else if rawStr[start] == '\'' {
		return extractQuotedStringSingle(rawStr, start)
	} else {
		// 尝试提取非字符串值（数字、布尔值等）
		return extractUnquotedValue(rawStr, start)
	}
}

func extractBoolFieldSmart(rawStr, fieldName string) (bool, error) {
	value, err := extractFieldSmart(rawStr, fieldName)
	if err != nil {
		return false, err
	}

	switch strings.ToLower(value) {
	case "true":
		return true, nil
	case "false":
		return false, nil
	default:
		return false, fmt.Errorf("不是有效的布尔值: %s", value)
	}
}
func extractUnquotedValue(s string, startIdx int) (string, error) {
	end := startIdx
	for end < len(s) && !isValueSeparator(s[end]) {
		end++
	}

	if end == startIdx {
		return "", fmt.Errorf("未找到有效的值")
	}

	return strings.TrimSpace(s[startIdx:end]), nil
}

// isValueSeparator 判断是否为值分隔符
func isValueSeparator(c byte) bool {
	return c == ',' || c == '}' || c == ']' || c == ' ' || c == '\t' || c == '\n'
}

// unescapeString 处理字符串转义
func unescapeString(s string) string {
	// 处理常见的转义序列
	replacer := strings.NewReplacer(
		`\"`, `"`,
		`\'`, `'`,
		`\n`, "\n",
		`\r`, "\r",
		`\t`, "\t",
		`\\`, `\`,
	)
	return replacer.Replace(s)
}

func extractParamsFromMap(params map[string]interface{}) (map[string]interface{}, error) {
	result := make(map[string]interface{})

	// 提取 path
	if path, ok := params["path"].(string); ok && path != "" {
		result["path"] = path
	} else {
		return nil, fmt.Errorf("缺少必要参数: path")
	}

	// 提取 content
	if content, ok := params["content"].(string); ok {
		result["content"] = content
	} else {
		return nil, fmt.Errorf("缺少必要参数: content")
	}

	// 提取 append
	if appendVal, ok := params["append"].(bool); ok {
		result["append"] = appendVal
	} else {
		result["append"] = false
	}

	// 提取可选参数
	if encoding, ok := params["encoding"].(string); ok {
		result["encoding"] = encoding
	}
	if format, ok := params["format"].(string); ok {
		result["format"] = format
	}

	return result, nil
}

func extractJSONFieldValue(rawStr, fieldName string) (string, error) {
	// 匹配模式: "fieldName": "value"
	pattern := fmt.Sprintf(`"%s"\s*:\s*"((?:\\.|[^"\\])*)"`, fieldName)
	re := regexp.MustCompile(pattern)

	matches := re.FindStringSubmatch(rawStr)
	if len(matches) == 0 {
		// 尝试单引号
		pattern = fmt.Sprintf(`'%s'\s*:\s*'((?:\\.|[^'\\])*)'`, fieldName)
		re = regexp.MustCompile(pattern)
		matches = re.FindStringSubmatch(rawStr)
	}

	if len(matches) < 2 {
		return "", fmt.Errorf("未找到字段: %s", fieldName)
	}

	value := matches[1]

	// 处理转义字符
	value = strings.ReplaceAll(value, `\"`, `"`)
	value = strings.ReplaceAll(value, `\'`, `'`)
	value = strings.ReplaceAll(value, `\n`, "\n")
	value = strings.ReplaceAll(value, `\r`, "\r")
	value = strings.ReplaceAll(value, `\t`, "\t")
	value = strings.ReplaceAll(value, `\\`, `\`)

	return value, nil
}

func extractJSONFieldBool(rawStr, fieldName string) (bool, bool) {
	// 方法1: 先找到字段位置，然后检查后面的值
	fieldPattern := fmt.Sprintf(`"%s"\s*:`, fieldName)
	re := regexp.MustCompile(fieldPattern)
	loc := re.FindStringIndex(rawStr)

	if loc == nil {
		// 尝试单引号
		fieldPattern = fmt.Sprintf(`'%s'\s*:`, fieldName)
		re = regexp.MustCompile(fieldPattern)
		loc = re.FindStringIndex(rawStr)
	}

	if loc == nil {
		return false, false
	}

	// 找到字段后的位置
	startIdx := loc[1]

	// 跳过空白字符
	for startIdx < len(rawStr) && (rawStr[startIdx] == ' ' || rawStr[startIdx] == '\t') {
		startIdx++
	}

	if startIdx >= len(rawStr) {
		return false, false
	}

	// 检查接下来的字符是否是 true 或 false
	if strings.HasPrefix(rawStr[startIdx:], "true") {
		// 确保 true 后面是逗号、花括号、空白或结束
		nextIdx := startIdx + 4
		if nextIdx >= len(rawStr) ||
			rawStr[nextIdx] == ',' ||
			rawStr[nextIdx] == '}' ||
			rawStr[nextIdx] == ']' ||
			rawStr[nextIdx] == ' ' ||
			rawStr[nextIdx] == '\t' ||
			rawStr[nextIdx] == '\n' {
			return true, true
		}
	} else if strings.HasPrefix(rawStr[startIdx:], "false") {
		// 确保 false 后面是逗号、花括号、空白或结束
		nextIdx := startIdx + 5
		if nextIdx >= len(rawStr) ||
			rawStr[nextIdx] == ',' ||
			rawStr[nextIdx] == '}' ||
			rawStr[nextIdx] == ']' ||
			rawStr[nextIdx] == ' ' ||
			rawStr[nextIdx] == '\t' ||
			rawStr[nextIdx] == '\n' {
			return false, true
		}
	}

	return false, false
}

func extractJSONFieldValueOptional(rawStr, fieldName string) (string, bool) {
	value, err := extractJSONFieldValue(rawStr, fieldName)
	if err != nil {
		return "", false
	}
	return value, true
}

func extractJSONFieldComplex(rawStr, fieldName string) (string, error) {
	// 找到字段的位置
	fieldPattern := fmt.Sprintf(`"%s"\s*:`, fieldName)
	re := regexp.MustCompile(fieldPattern)
	loc := re.FindStringIndex(rawStr)
	if loc == nil {
		// 尝试单引号
		fieldPattern = fmt.Sprintf(`'%s'\s*:`, fieldName)
		re = regexp.MustCompile(fieldPattern)
		loc = re.FindStringIndex(rawStr)
	}
	if loc == nil {
		return "", fmt.Errorf("未找到字段: %s", fieldName)
	}

	// 从字段位置开始，找到值的开始
	startIdx := loc[1]

	// 跳过空白字符
	for startIdx < len(rawStr) && (rawStr[startIdx] == ' ' || rawStr[startIdx] == '\t') {
		startIdx++
	}

	if startIdx >= len(rawStr) {
		return "", fmt.Errorf("字段 %s 的值位置无效", fieldName)
	}

	// 检查值的第一个字符
	firstChar := rawStr[startIdx]

	// 如果值以引号开始
	if firstChar == '"' || firstChar == '\'' {
		quoteChar := firstChar
		valueStart := startIdx + 1
		escaped := false
		var content strings.Builder

		for i := valueStart; i < len(rawStr); i++ {
			c := rawStr[i]

			if c == '\\' && !escaped {
				escaped = true
				continue
			}

			if c == quoteChar && !escaped {
				// 找到闭合引号
				return content.String(), nil
			}

			if escaped {
				switch c {
				case 'n':
					content.WriteByte('\n')
				case 'r':
					content.WriteByte('\r')
				case 't':
					content.WriteByte('\t')
				case '"':
					content.WriteByte('"')
				case '\'':
					content.WriteByte('\'')
				case '\\':
					content.WriteByte('\\')
				default:
					content.WriteByte(c)
				}
				escaped = false
			} else {
				content.WriteByte(c)
			}
		}
		return "", fmt.Errorf("未找到 %s 字段的闭合引号", fieldName)
	}

	// 如果值以 { 或 [ 开始（JSON 对象或数组）
	if firstChar == '{' || firstChar == '[' {
		stack := []byte{firstChar}
		var content strings.Builder
		content.WriteByte(firstChar)

		for i := startIdx + 1; i < len(rawStr); i++ {
			c := rawStr[i]
			content.WriteByte(c)

			if c == '{' {
				stack = append(stack, '{')
			} else if c == '}' {
				if len(stack) > 0 && stack[len(stack)-1] == '{' {
					stack = stack[:len(stack)-1]
					if len(stack) == 0 {
						return content.String(), nil
					}
				}
			} else if c == '[' {
				stack = append(stack, '[')
			} else if c == ']' {
				if len(stack) > 0 && stack[len(stack)-1] == '[' {
					stack = stack[:len(stack)-1]
					if len(stack) == 0 {
						return content.String(), nil
					}
				}
			}
		}
		return "", fmt.Errorf("未找到 %s 字段的闭合括号", fieldName)
	}

	// 简单值（数字等）
	endIdx := startIdx
	for endIdx < len(rawStr) {
		c := rawStr[endIdx]
		if c == ',' || c == '}' || c == ']' {
			break
		}
		endIdx++
	}

	if endIdx > startIdx {
		return strings.TrimSpace(rawStr[startIdx:endIdx]), nil
	}

	return "", fmt.Errorf("无法提取 %s 字段的值", fieldName)
}

func cleanJSONString(s string) string {
	// 1. 去除首尾空白
	s = strings.TrimSpace(s)

	// 2. 如果被引号包围，去除引号
	if len(s) >= 2 && ((s[0] == '"' && s[len(s)-1] == '"') || (s[0] == '\'' && s[len(s)-1] == '\'')) {
		s = s[1 : len(s)-1]
	}

	// 3. 修复未转义的控制字符
	var builder strings.Builder
	for _, r := range s {
		if r < 32 && r != '\n' && r != '\t' && r != '\r' {
			// 替换控制字符为空
			continue
		}
		builder.WriteRune(r)
	}
	s = builder.String()

	// 4. 修复常见的 JSON 格式问题
	s = strings.ReplaceAll(s, "\\'", "'")   // 将 \' 替换为 '
	s = strings.ReplaceAll(s, "\\\"", "\"") // 将 \" 替换为 "
	s = strings.ReplaceAll(s, "\\\\", "\\") // 将 \\ 替换为 \

	// 5. 确保是有效的 JSON 对象格式
	if !strings.HasPrefix(s, "{") {
		s = "{" + s
	}
	if !strings.HasSuffix(s, "}") {
		s = s + "}"
	}

	// 6. 修复缺失的引号（简单的启发式方法）
	re := regexp.MustCompile(`(\w+)\s*:`)
	s = re.ReplaceAllString(s, `"$1":`)

	return s
}

// AutoGenAssistant AutoGen助手Agent
type AutoGenAssistant struct {
	name          string
	modelConfig   *ModelConfig
	systemMessage string
	temperature   float64
	maxTokens     int
	httpClient    *http.Client
	fileLogger    *log.Logger
}

// NewAutoGenAssistant 创建AutoGen助手
func NewAutoGenAssistant(config AgentConfig, modelConfig *ModelConfig, filelogger *log.Logger) *AutoGenAssistant {
	return &AutoGenAssistant{
		name:          config.Name,
		modelConfig:   modelConfig,
		systemMessage: config.SystemMessage,
		temperature:   config.Temperature,
		maxTokens:     config.MaxTokens,
		httpClient:    &http.Client{Timeout: 60 * time.Second},
		fileLogger:    filelogger,
	}
}

// Name 返回Agent名称
func (a *AutoGenAssistant) Name() string {
	return a.name
}

// GetType 返回Agent类型
func (a *AutoGenAssistant) GetType() AgentType {
	return AgentTypeAutoGenAssistant
}

func (a *AutoGenAssistant) Generate(ctx context.Context, input string) (string, error) {

	requestBody := map[string]interface{}{
		"model": a.modelConfig.ModelName,
		"messages": []map[string]string{
			{"role": "system", "content": a.systemMessage},
			{"role": "user", "content": input},
		},
		"temperature": a.temperature,
		"max_tokens":  a.maxTokens,
	}

	jsonData, err := json.Marshal(requestBody)
	if err != nil {
		return "", fmt.Errorf("序列化请求失败: %w", err)
	}

	a.fileLogger.Printf("[INFO] assistant will call_llm | time: %s | msg len: %d | input: %s", time.Now().Format("2006-01-02 15:04:05"), len(input), input)

	req, err := http.NewRequestWithContext(ctx, "POST", a.modelConfig.BaseURL+"/chat/completions", bytes.NewBuffer(jsonData))
	if err != nil {
		return "", fmt.Errorf("创建请求失败: %w", err)
	}

	req.Header.Set("Content-Type", "application/json")
	req.Header.Set("Authorization", "Bearer "+a.modelConfig.APIKey)
	a.httpClient = &http.Client{Timeout: 180 * time.Second}
	resp, err := a.httpClient.Do(req)
	if err != nil {
		return "", fmt.Errorf("发送请求失败: %w", err)
	}
	defer resp.Body.Close()

	body0, err := io.ReadAll(resp.Body)
	if err != nil {
		a.fileLogger.Printf("[ERROR] assistant LLM调用失败: %v ", err)
		return "", fmt.Errorf("读取响应失败: %w", err)
	}
	body := CleanBytes(body0)
	if len(body0) != len(body) {
		a.fileLogger.Printf("[DEBUG] 响应编码转换: 原始长度=%d, 清理后长度=%d", len(body0), len(body))
	}

	a.fileLogger.Printf("[INFO] assistant call_llm | time: %s | msg len: %d | input: %s", time.Now().Format("2006-01-02 15:04:05"), len(body), body)

	if resp.StatusCode != http.StatusOK {
		return "", fmt.Errorf("API返回错误状态码: %d, 响应: %s", resp.StatusCode, string(body))
	}

	var response struct {
		Choices []struct {
			Message struct {
				Content string `json:"content"`
			} `json:"message"`
		} `json:"choices"`
		Error *struct {
			Message string `json:"message"`
		} `json:"error,omitempty"`
	}

	if err := json.Unmarshal(body, &response); err != nil {
		return "", fmt.Errorf("解析响应失败: %w", err)
	}

	if response.Error != nil {
		return "", fmt.Errorf("API错误: %s", response.Error.Message)
	}

	if len(response.Choices) == 0 {
		return "", errors.New("AutoGen助手返回空响应")
	}

	return response.Choices[0].Message.Content, nil
}

